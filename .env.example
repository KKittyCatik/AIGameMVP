# Copy this file to .env and fill in your values.
# docker compose will pick it up automatically.

# Required: your AI provider API key (OpenRouter, OpenAI, or any compatible service)
AI_API_KEY=your-api-key-here

# Optional: base URL of the OpenAI-compatible API (default: https://openrouter.ai/api/v1)
# AI_BASE_URL=https://openrouter.ai/api/v1

# Optional: model to use (default: google/gemma-4-26b-a4b-it:free)
# AI_MODEL=google/gemma-4-26b-a4b-it:free

# Optional: override the default system prompt
# SYSTEM_PROMPT=You are a Game Master...
